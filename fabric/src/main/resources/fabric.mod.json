    "issues": "https://github.com/nullabork/fw-paint-fabric/issues"
  },
  "license": "MIT",
  "icon": "assets/gradient/icon.png",
  "environment": "client",
  "entrypoints": {
    "client": ["co.fax.wang.fabric.GradientFabric"]
  },
  "depends": {
    "fabricloader": ">=0.19.3",
    "minecraft": "~26.2",
    "java": ">=25",
    "fabric-api": "*"
  }
}
